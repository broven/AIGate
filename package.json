{
  "name": "aigate",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter './packages/*' --parallel run dev",
    "dev:gateway": "pnpm --filter gateway dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "build": "pnpm --filter dashboard build",
    "db:generate": "pnpm --filter gateway db:generate",
    "db:migrate": "pnpm --filter gateway db:migrate",
    "seed": "pnpm --filter gateway seed"
  }
}
